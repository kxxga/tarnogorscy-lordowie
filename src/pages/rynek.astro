---

<Layout>
   
  <Carousel id="rynek-carousel" autoInit={false} opts={{ align: "start", loop: true }} class="flex w-full h-[300px] md:h-[550px] md:max-h-[550px]">
    <h1 class="absolute bottom-[-40px] left-1/2  text-center -translate-x-1/2 z-20 p-4 rounded-lg bg-cyan-700/90 text-xl lg:bottom-[-30px] lg:left-20 lg:translate-x-0 lg:text-3xl">
  <span class="font-bold">ul. Rynek 11</span> Tarnowskie Góry
</h1>
    <CarouselContent class="h-full">
     
          <CarouselItem class="h-full flex items-center justify-center">
            <Image
              src={`/images/rynek/4.webp`}
              alt={`Zdjęcie z karuzeli nr 1`}
              width={1000}
              height={1000} 
              */
              class="w-full h-full object-cover" 
            />
          </CarouselItem>
           <CarouselItem class="h-full flex items-center justify-center">
            <Image
              src={`/images/rynek/6.webp`}
              alt={`Zdjęcie z karuzeli nr 1`}
              width={1000}
              height={1000} 
              */
              class="w-full h-full object-cover" 
            />
          </CarouselItem>
           <CarouselItem class="h-full flex items-center justify-center">
            <Image
              src={`/images/rynek/8.webp`}
              alt={`Zdjęcie z karuzeli nr 1`}
              width={1000}
              height={1000} 
              */
              class="w-full h-full object-cover" 
            />
          </CarouselItem>
           <CarouselItem class="h-full flex items-center justify-center">
            <Image
              src={`/images/rynek/12.webp`}
              alt={`Zdjęcie z karuzeli nr 1`}
              width={1000}
              height={1000} 
              */
              class="w-full h-full object-cover" 
            />
          </CarouselItem>
    </CarouselContent>
  </Carousel>
  <Separator  />
  <Team1
    heading="Poznaj nas"
    description="Poznaj naszą ekipę"
    members={members}
  />
  
  <div class="bg-neutral-900">
    
    <Separator class="mb-10" />
    <div class="w-full flex justify-center">
  <span
      class="mb-10 bg-cyan-600/50 text-white inline-block rounded-full px-4 py-1.5 text-sm font-medium"
    >
      Wirtualny spacer salonu
    </span>
</div>
    <Tour />
    <Separator class="mt-10" />
  </div>
  <div class="mt-20">
    <Locations  />
  </div>
</Layout
>

<script>
  import EmblaCarousel from 'embla-carousel';
  import Autoplay from 'embla-carousel-autoplay';

  const setupCarousel = () => {
    const carouselRoot = document.getElementById('rynek-carousel');
    const viewportNode = carouselRoot?.querySelector('.overflow-hidden') as HTMLElement;

    if (viewportNode) {
      const autoplay = Autoplay({ 
        delay: 3000, 
        stopOnInteraction: false,
        stopOnMouseEnter: true
      });

      EmblaCarousel(viewportNode, { align: 'start', loop: true }, [autoplay]);
    }
  };

  document.addEventListener('DOMContentLoaded', setupCarousel);
  
  document.addEventListener('astro:page-load', setupCarousel);
</script>