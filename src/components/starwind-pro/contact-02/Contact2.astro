---
import type { HTMLAttributes } from "astro/types";
import { tv } from "tailwind-variants";

import { Button } from "@/components/starwind/button";
import { Card, CardContent } from "@/components/starwind/card";
import { Input } from "@/components/starwind/input";
import { Label } from "@/components/starwind/label";
import { Textarea } from "@/components/starwind/textarea";
import Checkbox from "@/components/starwind/checkbox";

interface Props extends HTMLAttributes<"section"> {
  badge?: string;
  heading?: string;
  description?: string;
}

const sectionStyles = tv({
  base: "@container mx-auto w-full max-w-3xl px-4 py-24",
});

const {
  badge = "Contact",
  heading = "Send Us a Message",
  description = "Fill out the form below and we'll get back to you as soon as possible.",
  class: className,
  ...rest
} = Astro.props;
---

<section id="kontakt" class={sectionStyles({ class: className })} {...rest}>
  <div class="text-center">
    <span
      class="bg-cyan-600/50 text-white inline-block rounded-full px-4 py-1.5 text-sm font-medium"
    >
      {badge}
    </span>
    <h2
      class="font-heading mt-6 text-3xl font-bold tracking-tight @xl:text-4xl @3xl:text-5xl"
    >
      {heading}
    </h2>
    <p class="text-muted-foreground mx-auto mt-4 max-w-xl text-lg">
      {description}
    </p>
  </div>

  <Card class="mt-10">
    <CardContent>
      <form class="space-y-6" id="contact-form-02" name="contact-form">
        <div class="grid gap-6 @xl:grid-cols-2">
          <div class="flex flex-col gap-1">
            <Label for="contact-name-02">Imię</Label>
            <Input
              id="contact-name-02"
              name="name"
              type="text"
              placeholder="Jan Nowak"
              required
            />
          </div>
          <div class="flex flex-col gap-1">
            <Label for="contact-email-02">Email</Label>
            <Input
              id="contact-email-02"
              name="email"
              type="email"
              placeholder="jannowak@gmail.com"
              required
            />
          </div>
        </div>
 <div class="flex flex-col gap-1">
          <Label for="contact-subject-03">Numer telefonu</Label>
          <Input
            id="contact-subject-03"
            name="phone"
            type="text"
            placeholder="+48 123 456 789"
            required
          />
        </div>
      

        <div class="flex flex-col gap-1">
          <Label for="contact-message-05">Wiadomość</Label>
          <Textarea
            id="contact-message-05"
            name="message"
            placeholder="Opisz swoją wiadomość..."
            rows={5}
            required
          />
        </div>

            <div class="flex flex-col gap-1">
              <Checkbox size="sm" id="contact-consent-01" name="consent" required label={`Wyrażam zgodę na przetwarzanie moich danych osobowych zgodnie z <a href="/polityka-prywatnosci" target="_blank" class="text-cyan-500 hover:underline">polityką prywatności</a>.`}>
              
              </Checkbox>
               
                 
            
         
        </div>

        <p id="form-status" class="text-sm font-medium hidden"></p>

        <Button
          variant="primary"
          type="submit"
          id="submit-btn"
          class="bg-cyan-600 hover:bg-cyan-700 w-full @xl:w-auto"
        >
          Wyślij wiadomość
        </Button>
      </form>
    </CardContent>
  </Card>

  <p class="text-muted-foreground mt-6 text-center text-sm">
    Odpowiadamy zazwyczaj w ciągu 1-2 dni roboczych.
  </p>
</section>

<script>
  import { actions } from "astro:actions";

  function handleFormSubmit() {
    const form = document.querySelector("#contact-form-02") as HTMLFormElement;
    const submitBtn = document.querySelector(
      "#submit-btn",
    ) as HTMLButtonElement;
    const statusText = document.querySelector(
      "#form-status",
    ) as HTMLParagraphElement;

    if (form && submitBtn && statusText) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        submitBtn.disabled = true;
        submitBtn.textContent = "Wysyłanie...";
        statusText.classList.add("hidden");

        const { data, error } = await actions.send(new FormData(form));

        submitBtn.disabled = false;
        submitBtn.textContent = "Wyślij Wiadomość";

        if (error) {
          statusText.textContent = `Błąd: ${error.message || "Nie udało się wysłać wiadomości."}`;
          statusText.className = "text-sm font-medium text-destructive block";
        } else {
          statusText.textContent = "Wiadomość została wysłana pomyślnie!";
          statusText.className = "text-sm font-medium text-green-600 block";
          form.reset();
        }
      });
    }
  }

  handleFormSubmit();
  document.addEventListener("astro:after-swap", handleFormSubmit);
</script>
