---
import type { HTMLAttributes } from "astro/types";
import { tv } from "tailwind-variants";

import { Prose } from "@/components/starwind/prose";

interface Props extends HTMLAttributes<"article"> {
  /** Legal page title */
  title: string;
  /** Brief description or subtitle */
  description: string;
  /** Publication date string */
  pubDate: string;
  /** Last updated date string */
  updatedDate?: string;
}

const sectionStyles = tv({
  base: "@container mx-auto w-full max-w-4xl px-4 py-24",
});

const {
  title,
  description,
  pubDate,
  updatedDate,
  class: className,
  ...rest
} = Astro.props;
---

<article class={sectionStyles({ class: className })} {...rest}>
  <!-- Header -->
  <header class="mx-auto max-w-2xl text-center">
    <h1
      class="mt-16 font-heading text-3xl font-bold tracking-tight @xl:text-4xl @3xl:text-5xl"
    >
      {title}
    </h1>

    <p class="text-muted-foreground mt-4 text-lg text-pretty">
      {description}
    </p>

    <div
      class="text-muted-foreground mt-4 flex items-center justify-center gap-1.5 text-sm"
    >
      <span>Data publikacji:</span>
      <time datetime={pubDate}>{pubDate}</time>
      {
        updatedDate && (
          <>
            <span>&middot;</span>
            <span>
              Updated <time datetime={updatedDate}>{updatedDate}</time>
            </span>
          </>
        )
      }
    </div>
  </header>

  <!-- Prose content slot -->
  <div class="mt-12">
    <Prose class="max-w-none">
      <slot />
    </Prose>
  </div>
</article>
